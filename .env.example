# LLM_PROVIDER=deepseek | ollama
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-your-deepseek-key
OLLAMA_ENDPOINT=http://localhost:11434/api/chat
OLLAMA_MODEL=gemma4
EMAIL_HASH_SALT=replace-with-a-long-random-secret
ADMIN_TOKEN=replace-with-an-admin-token
REVIEW_MIN_DELAY_DAYS=3
REVIEW_MAX_DELAY_DAYS=14

# public

TEAMRADAR_EDITION=public
PUBLIC_EVENT_COLLECTOR_CRON=1
PUBLIC_EVENT_ADMIN_AGENT=1
PUBLIC_EVENT_ADMIN_AGENT_THRESHOLD=0.88
PUBLIC_EVENT_AGENT_STALE_DAYS=14

# LLM_MOCK=1
